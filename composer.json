{
    "name": "eveses/sdk",
    "description": "Official Eveses SDK for PHP — activations, wallet, catalog, webhooks.",
    "type": "library",
    "license": "MIT",
    "keywords": ["eveses", "sms", "activations", "sdk", "api"],
    "require": {
        "php": "^8.1",
        "ext-curl": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Eveses\\Sdk\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Eveses\\Sdk\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit --bootstrap vendor/autoload.php tests"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
